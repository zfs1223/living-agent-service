# Living Agent Service Dockerfile - 离线构建版本
# 使用本地保存的依赖，无需网络连接
#
# 前置条件:
#   1. 运行 python image/download_images.py 下载依赖
#   2. 运行 powershell -File image\load_images.ps1 加载镜像
#
# 构建:
#   docker build -f living-agent-app/Dockerfile.local -t living-agent-service .

# ===========================================
# Stage 1: Build stage - 使用本地依赖
# ===========================================
FROM maven:3.9-eclipse-temurin-21 AS builder

WORKDIR /build

# 解压本地 Maven 仓库 (离线依赖)
COPY image/maven-repo.tar /tmp/
RUN mkdir -p /root/.m2 && \
    cd /root/.m2 && \
    tar -xvf /tmp/maven-repo.tar && \
    rm /tmp/maven-repo.tar

# 复制 pom 文件
COPY pom.xml ./
COPY living-agent-app/pom.xml living-agent-app/pom.xml
COPY living-agent-core/pom.xml living-agent-core/pom.xml
COPY living-agent-skill/pom.xml living-agent-skill/pom.xml
COPY living-agent-gateway/pom.xml living-agent-gateway/pom.xml
COPY living-agent-perception/pom.xml living-agent-perception/pom.xml

# 复制源代码
COPY living-agent-app living-agent-app
COPY living-agent-core living-agent-core
COPY living-agent-skill living-agent-skill
COPY living-agent-gateway living-agent-gateway
COPY living-agent-perception living-agent-perception

# 构建应用 (优先使用本地缓存，缺失时从网络下载)
RUN mvn clean package -DskipTests -pl living-agent-app -am

# ===========================================
# Stage 2: Runtime stage - 使用本地基础镜像
# ===========================================
FROM living-agent-system-deps:1.0

LABEL maintainer="Living Agent Team"
LABEL description="AI Enterprise Management Agent Service - Offline Build"
LABEL version="1.0.0"

# 切换回 root 用户进行安装
USER root

# 设置工作目录
WORKDIR /app

# 复制应用 JAR
COPY --from=builder /build/living-agent-app/target/*.jar app.jar

# 创建 lib 目录
RUN mkdir -p /app/lib

# 复制 Rust native 库 (如果存在)
RUN --mount=type=bind,source=image,target=/tmp/image \
    if [ -f /tmp/image/libliving_agent_native.so ]; then \
        cp /tmp/image/libliving_agent_native.so /app/lib/; \
    fi

# 复制技能目录
COPY living-agent-skill/src/main/resources/skills /app/skills

# 解压本地 Python wheels 并安装 (包含基础依赖和 AI 模型依赖)
# 离线部署: 使用 --no-index 强制只使用本地 wheel，禁止网络下载
# 先安装 setuptools/wheel 以便编译源码包
COPY image/python-wheels.tar /tmp/
RUN mkdir -p /tmp/wheels && \
    tar -xf /tmp/python-wheels.tar -C /tmp/wheels && \
    echo "=== Installing build tools first ===" && \
    pip3 install --no-cache-dir --break-system-packages --no-index --find-links=/tmp/wheels setuptools wheel && \
    echo "=== Installing Python packages from local wheels (offline) ===" && \
    pip3 install --no-cache-dir --break-system-packages --no-index --find-links=/tmp/wheels \
        pypdf pdfplumber python-docx openpyxl python-pptx huggingface-hub requests beautifulsoup4 lxml \
        sherpa-ncnn soundfile scipy numpy \
        torch torchaudio transformers \
        librosa Unidecode phonemizer \
        cn2an eng-to-ipa jieba pypinyin \
        mecab-python3 fugashi jaconv \
        nltk unidic-lite num2words pykakasi g2p-en anyascii jamo gruut g2pkk pydub inflect langid loguru cached-path python-mecab-ko python-mecab-ko-dic \
    && echo "=== Verifying installations ===" && \
    python3 -c "import numpy; print(f'numpy: {numpy.__version__}')" && \
    python3 -c "import scipy; print(f'scipy: {scipy.__version__}')" && \
    python3 -c "import soundfile; print('soundfile: OK')" && \
    python3 -c "import sherpa_ncnn; print('sherpa_ncnn: OK')" && \
    rm -rf /tmp/wheels /tmp/python-wheels.tar

# 复制 NLTK 数据 (MeloTTS 需要)
COPY image/nltk_data /opt/nltk_data
ENV NLTK_DATA=/opt/nltk_data

# 安装预编译的 llama.cpp (支持 Qwen3.5)
# 运行 python image/build_llama_cpp.py 预编译
COPY image/llama-cpp-built.tar /tmp/
RUN cd /tmp && \
    mkdir -p /opt/llama.cpp && \
    cd /opt/llama.cpp && \
    tar -xvf /tmp/llama-cpp-built.tar && \
    rm /tmp/llama-cpp-built.tar

# 设置 llama.cpp 环境变量
ENV LLAMA_CPP_PATH=/opt/llama.cpp
ENV PATH="${LLAMA_CPP_PATH}/build/bin:${PATH}"

# 复制模型守护进程脚本
COPY scripts/python /opt/python_scripts

# 复制启动脚本 (在切换用户之前设置权限)
COPY living-agent-app/entrypoint.sh /app/entrypoint.sh

# 设置权限 (基础镜像已配置 livingagent 用户)
RUN mkdir -p /app/data /app/logs /app/lib && \
    chmod +x /app/entrypoint.sh /opt/python_scripts/*.py 2>/dev/null || true && \
    chown -R livingagent:livingagent /app /opt/python_scripts 2>/dev/null || true

# 设置环境变量
ENV LIVING_AGENT_DATA_PATH=/app/data \
    LIVING_AGENT_SKILLS_PATH=/app/skills \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    LD_LIBRARY_PATH=/app/lib:$LD_LIBRARY_PATH

# 切换到非 root 用户
USER livingagent

# 暴露端口
EXPOSE 8380

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8380/actuator/health || exit 1

# JVM 选项
ENV JAVA_OPTS="-Xms512m -Xmx1536m -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"

# 启动应用 (使用启动脚本，先启动模型守护进程)
ENTRYPOINT ["/app/entrypoint.sh"]
